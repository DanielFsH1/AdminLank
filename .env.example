# Firebase web config. These values are project-specific but not secret; keep
# production values in .env.local, not in Git.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=
VITE_FIREBASE_HOSTING_URL=
VITE_FIREBASE_CONSOLE_URL=

# Base URL for deployed Cloud Functions, for example:
# https://REGION-PROJECT_ID.cloudfunctions.net
VITE_CLOUD_FUNCTIONS_URL=

# Non-secret KDF salt for existing encrypted vault data. The vault key/passphrase
# must be entered at runtime and must never use a VITE_* variable.
VAULT_KEY_SEED=
VITE_VAULT_SALT=

# Cloud Functions runtime env. Configure in Firebase/GCP, not in Git.
DASHBOARD_ADMIN_UID=
LANK_FROM_EMAIL=
FIREBASE_PROJECT_ID=
TELEGRAM_WEBHOOK_URL=
